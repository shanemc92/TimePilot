# Copy this to .env and fill in real values. NEVER commit .env - it's
# already in .gitignore.

# --- Postgres ---
POSTGRES_USER=timepilot
# Generate with: openssl rand -hex 24
# (use hex, not base64 - base64 can contain / + = which break when this
# value is interpolated straight into the postgresql:// URL below)
POSTGRES_PASSWORD=

# --- App secrets ---
# Signs session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
# Encrypts all stored data at rest (AES-256). Generate with: python crypto.py
# Losing this key makes all existing data permanently unreadable - back it
# up somewhere safe and separate from your database backups.
TIMEPILOT_MASTER_KEY=

# --- ntfy (optional) ---
# The ntfy server URL and topic are set per-user in Settings, not here.
# Set this to true ONLY if your ntfy server is on a private/internal address
# (e.g. http://192.168.1.20 or http://ntfy.lan). By default TimePilot refuses
# to send to private addresses, for the same reason it refuses to fetch
# calendar URLs from them - otherwise any registered user could point the
# server at your internal network. Leave unset if you use ntfy.sh or a
# public hostname.
TIMEPILOT_ALLOW_PRIVATE_NTFY=false

# --- Login page banner (optional) ---
# Shown above the login/signup forms. Blank/unset (default) shows nothing.
# Useful for a public demo instance, e.g.:
# TIMEPILOT_LOGIN_BANNER=Demo instance - all data is wiped every 24 hours.
TIMEPILOT_LOGIN_BANNER=

# --- Disable signup (optional) ---
# When true, /signup is disabled (404) and the "Sign up" link is hidden on
# the login page - only existing accounts can log in. Useful for a demo
# instance seeded via sample_data.py where you don't want public registration.
TIMEPILOT_DISABLE_SIGNUP=false

# --- Rate-limit storage (optional) ---
# Login/signup rate limiting uses in-memory storage by default, which is
# per-worker (gunicorn runs 2 by default - see Dockerfile), not shared
# across them. Fine for this app's threat model on a small self-hosted
# instance. If you run more workers or multiple replicas and want limits
# actually shared across all of them, point this at Redis instead:
# TIMEPILOT_RATELIMIT_STORAGE_URI=redis://localhost:6379
TIMEPILOT_RATELIMIT_STORAGE_URI=memory://
