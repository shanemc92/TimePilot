# Copy this to .env and fill in real values. NEVER commit .env - it's
# already in .gitignore.

# --- Postgres ---
POSTGRES_USER=timepilot
# Generate with: openssl rand -hex 24
# (use hex, not base64 - base64 can contain / + = which break when this
# value is interpolated straight into the postgresql:// URL below)
POSTGRES_PASSWORD=

# --- App secrets ---
# Signs session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
# Encrypts all stored data at rest (AES-256). Generate with: python crypto.py
# Losing this key makes all existing data permanently unreadable - back it
# up somewhere safe and separate from your database backups.
TIMEPILOT_MASTER_KEY=
